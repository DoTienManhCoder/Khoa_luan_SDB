# AutoShotV2 Web environment template
# Copy this file to .env for local Docker development.
# Do not put real secrets in this example file.

# Frontend
VITE_API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend
BACKEND_PORT=8000
STORAGE_DIR=/app/storage
MAX_UPLOAD_MB=300
MAX_DURATION_SEC=600
JOB_TTL_HOURS=24

# MongoDB
# Local Docker option:
# MONGODB_URI=mongodb://mongo:27017
#
# MongoDB Atlas option:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority&appName=<app-name>
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=autoshot
MONGO_PORT=27017

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>
CLOUDINARY_FOLDER=autoshot

# AutoShotV2 model
AUTOSHOT_MODEL_PATH=/app/models/deploy.pth
AUTOSHOT_DEVICE=auto
AUTOSHOT_USE_BASELINE=false

# Optional overrides. Leave empty to use checkpoint metadata or deployment defaults.
AUTOSHOT_DEFAULT_TEMPERATURE=
AUTOSHOT_DEFAULT_SIGMA=
AUTOSHOT_DEFAULT_THRESHOLD=
